dataset_path: recursal/longbench-v2
test_split: train
output_type: generate_until
doc_to_text: !function utils.doc_to_text
doc_to_target: "{{ ['A','B','C','D'][answer] if answer is number else answer }}"
generation_kwargs:
  max_gen_toks: 32768
  do_sample: false
  temperature: 0.0
  until: []
filter_list:
  - name: "strict-match"
    filter:
      - function: "regex"
        regex_pattern: "(?i)(?:correct\\s+answer\\s+is\\s*[\\*:\\(\\s]*|\\\\boxed\\{)([A-D])"
        group_select: -1
        fallback: "[invalid]"
      - function: "take_first"
  - name: "flexible-extract"
    filter:
      - function: "regex"
        regex_pattern: "\\b([A-D])\\b"
        group_select: -1
        fallback: "[invalid]"
      - function: "take_first"
metric_list:
  - metric: exact_match
    aggregation: mean
    higher_is_better: true
    ignore_case: true
    ignore_punctuation: true
metadata:
  version: 1.0